@@ -0,0 +1,67 @@
+import { describe, it, expect } from 'vitest'
+import { Kysely } from 'kysely'
+import { createClient } from '@libsql/client'
+import { LibsqlDialect } from '@libsql/kysely-libsql'
+import { runMigrations } from '../database/migrationRunner'
+import { WorldEntityRepository } from './worldEntityRepository'
+import { WorldSyncJobRepository } from './worldSyncJobRepository'
+import { WorldEntityType, WorldSyncOperation, WorldSyncStatus } from '@shared-types/world'
+import type { Database } from '../database/schema'
+
+async function setup(): Promise<{
+  entities: WorldEntityRepository
+  jobs: WorldSyncJobRepository
+}> {
+  const client = createClient({ url: ':memory:' })
+  await runMigrations(client)
+  const db = new Kysely<Database>({ dialect: new LibsqlDialect({ client }) })
+  return {
+    entities: new WorldEntityRepository(db),
+    jobs: new WorldSyncJobRepository(db)
+  }
+}
+
+describe('WorldSyncJobRepository', () => {
+  it('enqueue creates a pending job and replaces older pending for the same pin', async () => {
+    const { entities, jobs } = await setup()
+    const entity = await entities.create({
+      entityType: WorldEntityType.Shop,
+      entityId: null,
+      name: 'Tienda',
+      position: { lat: 10, lng: 20 },
+      properties: {}
+    })
+
+    const first = await jobs.enqueue(entity, WorldSyncOperation.Create)
+    expect(first.status).toBe(WorldSyncStatus.Pending)
+
+    const second = await jobs.enqueue(
+      { ...entity, name: 'Tienda 2' },
+      WorldSyncOperation.Update
+    )
+    expect(second.id).not.toBe(first.id)
+
+    const pending = await jobs.listPending(10)
+    expect(pending).toHaveLength(1)
+    expect(pending[0].id).toBe(second.id)
+    expect(JSON.parse(pending[0].payloadJson).name).toBe('Tienda 2')
+  })
+
+  it('markFailed schedules retry and listPending includes it after next_retry_at', async () => {
+    const { entities, jobs } = await setup()
+    const entity = await entities.create({
+      entityType: WorldEntityType.Npc,
+      entityId: null,
+      name: 'Guarda',
+      position: { lat: 1, lng: 2 },
+      properties: {}
+    })
+    const job = await jobs.enqueue(entity, WorldSyncOperation.Create)
+    await jobs.markFailed(job.id, 'boom', 1)
+
+    const listed = await jobs.listForEntity(entity.worldId)
+    expect(listed[0].status).toBe(WorldSyncStatus.Failed)
+    expect(listed[0].lastError).toBe('boom')
+    expect(listed[0].nextRetryAt).toBeTruthy()
+  })
+})
diff --git a/src/main/worldEditor/worldSyncJobRepository.ts b/src/main/worldEditor/worldSyncJobRepository.ts
new file mode 100644
index 0000000..4cb23c4
--- /dev/null
+++ b/src/main/worldEditor/worldSyncJobRepository.ts
@@ -0,0 +1,165 @@
+import type { Kysely } from 'kysely'
+import type { Database } from '../database/schema'
+import {
+  WorldSyncOperation,
+  WorldSyncStatus,
+  type WorldSyncJob,
+  type WorldEntity
+} from '@shared-types/world'
+
+interface JobRow {
+  id: number
+  world_entity_id: string
+  operation: string
+  payload_json: string
+  status: string
+  attempts: number
+  next_retry_at: string | null
+  last_error: string | null
+  created_at: string
+  updated_at: string
+}
+
+function toJob(row: JobRow): WorldSyncJob {
+  return {
+    id: row.id,
+    worldEntityId: row.world_entity_id,
+    operation: row.operation as WorldSyncOperation,
+    payloadJson: row.payload_json,
+    status: row.status as WorldSyncStatus,
+    attempts: row.attempts,
+    nextRetryAt: row.next_retry_at,
+    lastError: row.last_error,
+    createdAt: row.created_at,
+    updatedAt: row.updated_at
+  }
+}
+
+export class WorldSyncJobRepository {
+  constructor(private db: Kysely<Database>) {}
+
+  async enqueue(entity: WorldEntity, operation: WorldSyncOperation): Promise<WorldSyncJob> {
+    const now = new Date().toISOString()
+    // Descarta trabajos pendientes previos del mismo pin (el último gana).
+    await this.db
+      .deleteFrom('world_sync_jobs')
+      .where('world_entity_id', '=', entity.worldId)
+      .where('status', 'in', [
+        WorldSyncStatus.Pending,
+        WorldSyncStatus.Failed,
+        WorldSyncStatus.Offline,
+        WorldSyncStatus.Local
+      ])
+      .execute()
+
+    const payload = JSON.stringify({
+      worldId: entity.worldId,
+      entityType: entity.entityType,
+      entityId: entity.entityId,
+      name: entity.name,
+      position: entity.position,
+      rotation: entity.rotation,
+      enabled: entity.enabled,
+      properties: entity.properties,
+      operation
+    })
+
+    const inserted = await this.db
+      .insertInto('world_sync_jobs')
+      .values({
+        world_entity_id: entity.worldId,
+        operation,
+        payload_json: payload,
+        status: WorldSyncStatus.Pending,
+        attempts: 0,
+        next_retry_at: null,
+        last_error: null,
+        created_at: now,
+        updated_at: now
+      })
+      .returningAll()
+      .executeTakeFirstOrThrow()
+
+    return toJob(inserted as JobRow)
+  }
+
+  async listPending(limit = 50): Promise<WorldSyncJob[]> {
+    const now = new Date().toISOString()
+    const rows = await this.db
+      .selectFrom('world_sync_jobs')
+      .selectAll()
+      .where((eb) =>
+        eb.or([
+          eb('status', '=', WorldSyncStatus.Pending),
+          eb.and([
+            eb('status', '=', WorldSyncStatus.Failed),
+            eb.or([eb('next_retry_at', 'is', null), eb('next_retry_at', '<=', now)])
+          ]),
+          eb('status', '=', WorldSyncStatus.Offline)
+        ])
+      )
+      .orderBy('id', 'asc')
+      .limit(limit)
+      .execute()
+    return rows.map((row) => toJob(row as JobRow))
+  }
+
+  async listForEntity(worldEntityId: string): Promise<WorldSyncJob[]> {
+    const rows = await this.db
+      .selectFrom('world_sync_jobs')
+      .selectAll()
+      .where('world_entity_id', '=', worldEntityId)
+      .orderBy('id', 'desc')
+      .limit(20)
+      .execute()
+    return rows.map((row) => toJob(row as JobRow))
+  }
+
+  async markSyncing(id: number): Promise<void> {
+    await this.db
+      .updateTable('world_sync_jobs')
+      .set({ status: WorldSyncStatus.Syncing, updated_at: new Date().toISOString() })
+      .where('id', '=', id)
+      .execute()
+  }
+
+  async markSynced(id: number): Promise<void> {
+    await this.db
+      .updateTable('world_sync_jobs')
+      .set({
+        status: WorldSyncStatus.Synced,
+        last_error: null,
+        updated_at: new Date().toISOString()
+      })
+      .where('id', '=', id)
+      .execute()
+  }
+
+  async markFailed(id: number, error: string, attempts: number): Promise<void> {
+    const delayMs = Math.min(60_000, 2_000 * Math.pow(2, Math.min(attempts, 5)))
+    const next = new Date(Date.now() + delayMs).toISOString()
+    await this.db
+      .updateTable('world_sync_jobs')
+      .set({
+        status: WorldSyncStatus.Failed,
+        last_error: error.slice(0, 500),
+        attempts,
+        next_retry_at: next,
+        updated_at: new Date().toISOString()
+      })
+      .where('id', '=', id)
+      .execute()
+  }
+
+  async markOffline(id: number, error: string): Promise<void> {
+    await this.db
+      .updateTable('world_sync_jobs')
+      .set({
+        status: WorldSyncStatus.Offline,
+        last_error: error.slice(0, 500),
+        updated_at: new Date().toISOString()
+      })
+      .where('id', '=', id)
+      .execute()
+  }
+}
diff --git a/src/main/worldEditor/worldSyncService.ts b/src/main/worldEditor/worldSyncService.ts
new file mode 100644
index 0000000..8e35a70
--- /dev/null
+++ b/src/main/worldEditor/worldSyncService.ts
@@ -0,0 +1,174 @@
+import type { Kysely } from 'kysely'
+import type { Database } from '../database/schema'
+import { authService } from '../auth/authService'
+import { WorldEntityRepository } from './worldEntityRepository'
+import { WorldSyncJobRepository } from './worldSyncJobRepository'
+import {
+  WorldEntityType,
+  WorldSyncOperation,
+  WorldSyncStatus,
+  type PublishWorldRequest,
+  type WorldEntity,
+  type WorldSyncJob
+} from '@shared-types/world'
+
+const TYPE_MAP: Record<string, string> = {
+  [WorldEntityType.Object]: 'item',
+  [WorldEntityType.Enemy]: 'enemy',
+  [WorldEntityType.Npc]: 'npc',
+  [WorldEntityType.Chest]: 'chest',
+  [WorldEntityType.Shop]: 'shop',
+  [WorldEntityType.Quest]: 'mission',
+  [WorldEntityType.Resource]: 'item',
+  [WorldEntityType.Plant]: 'item',
+  [WorldEntityType.Marker]: 'item',
+  [WorldEntityType.Building]: 'item',
+  [WorldEntityType.SpawnPoint]: 'enemy',
+  [WorldEntityType.Teleporter]: 'item',
+  [WorldEntityType.Event]: 'item',
+  [WorldEntityType.Zone]: 'item'
+}
+
+/**
+ * Cola offline-first: encola cambios locales y los empuja al servidor del juego
+ * (POST /api/player/world/upsert | /world/delete) usando la sesión admin.
+ */
+export class WorldSyncService {
+  private jobs: WorldSyncJobRepository
+  private entities: WorldEntityRepository
+
+  constructor(db: Kysely<Database>) {
+    this.jobs = new WorldSyncJobRepository(db)
+    this.entities = new WorldEntityRepository(db)
+  }
+
+  async enqueueEntity(entity: WorldEntity, operation: WorldSyncOperation): Promise<WorldSyncJob> {
+    await this.entities.setSyncState(entity.worldId, {
+      syncStatus: WorldSyncStatus.Pending,
+      lastSyncError: null
+    })
+    const fresh = (await this.entities.get(entity.worldId)) || entity
+    return this.jobs.enqueue(fresh, operation)
+  }
+
+  async publish(request: PublishWorldRequest): Promise<{ published: number; failed: number }> {
+    const headers = authService.authHeaders()
+    if (!headers) {
+      throw new Error('Inicia sesión de administrador para subir al mundo')
+    }
+
+    let pending = await this.jobs.listPending(100)
+    if (request.selectedWorldIds?.length) {
+      const set = new Set(request.selectedWorldIds)
+      pending = pending.filter((job) => set.has(job.worldEntityId))
+    } else if (!request.publishAll && !request.selectedWorldIds) {
+      // publishAll false + sin selección → no-op
+      pending = []
+    }
+
+    let published = 0
+    let failed = 0
+    const base = authService.serverUrl()
+
+    for (const job of pending) {
+      await this.jobs.markSyncing(job.id)
+      await this.entities.setSyncState(job.worldEntityId, { syncStatus: WorldSyncStatus.Syncing })
+
+      try {
+        const payload = JSON.parse(job.payloadJson) as {
+          worldId: string
+          entityType: string
+          name: string
+          position: { lat: number; lng: number }
+          properties: Record<string, unknown>
+          enabled: boolean
+          operation: string
+        }
+
+        if (job.operation === WorldSyncOperation.Delete || payload.operation === 'delete') {
+          await this.postJson(base + '/api/player/world/delete', headers, { id: payload.worldId })
+        } else {
+          const type = TYPE_MAP[payload.entityType] || 'item'
+          await this.postJson(base + '/api/player/world/upsert', headers, {
+            id: payload.worldId,
+            type,
+            x: payload.position.lat,
+            y: payload.position.lng,
+            data: {
+              nombre: payload.name,
+              name: payload.name,
+              enabled: payload.enabled,
+              ...(payload.properties || {})
+            }
+          })
+        }
+
+        await this.jobs.markSynced(job.id)
+        await this.entities.setSyncState(job.worldEntityId, {
+          syncStatus: WorldSyncStatus.Synced,
+          lastSyncError: null,
+          syncAttempts: 0,
+          serverVersion: Date.now()
+        })
+        published += 1
+      } catch (error) {
+        const message = error instanceof Error ? error.message : 'Error desconocido'
+        const attempts = job.attempts + 1
+        const offline = /fetch|network|ECONN|ENOTFOUND|timeout|Failed to fetch|aborted/i.test(message)
+        if (offline) {
+          await this.jobs.markOffline(job.id, message)
+          await this.entities.setSyncState(job.worldEntityId, {
+            syncStatus: WorldSyncStatus.Offline,
+            lastSyncError: message,
+            syncAttempts: attempts
+          })
+        } else {
+          await this.jobs.markFailed(job.id, message, attempts)
+          await this.entities.setSyncState(job.worldEntityId, {
+            syncStatus: WorldSyncStatus.Failed,
+            lastSyncError: message,
+            syncAttempts: attempts
+          })
+        }
+        failed += 1
+      }
+    }
+
+    return { published, failed }
+  }
+
+  async retryFailed(): Promise<{ retried: number }> {
+    const result = await this.publish({ publishAll: true })
+    return { retried: result.published + result.failed }
+  }
+
+  async jobsForEntity(worldId: string): Promise<WorldSyncJob[]> {
+    return this.jobs.listForEntity(worldId)
+  }
+
+  private async postJson(
+    url: string,
+    headers: Record<string, string>,
+    body: unknown
+  ): Promise<void> {
+    const controller = new AbortController()
+    const timer = setTimeout(() => controller.abort(), 25000)
+    try {
+      const r = await fetch(url, {
+        method: 'POST',
+        headers,
+        body: JSON.stringify(body),
+        signal: controller.signal
+      })
+      const data = (await r.json().catch(() => ({}))) as { ok?: boolean; error?: string }
+      if (r.status === 401 || r.status === 403) {
+        throw new Error('Sesión expirada o sin permiso de administrador — vuelve a iniciar sesión')
+      }
+      if (!r.ok || data.ok === false) {
+        throw new Error(data.error || 'Error HTTP ' + r.status)
+      }
+    } finally {
+      clearTimeout(timer)
+    }
+  }
+}
