+import type { AdminLoginRequest, AdminLoginResult, AdminSessionPublic } from '@shared-types/auth'
+import { adminSessionStore, DEFAULT_SERVER, toPublic, type PrivateSession } from './sessionStore'
+
+function decodeJwtExp(token: string): string | null {
+  try {
+    const part = token.split('.')[1]
+    if (!part) return null
+    const json = JSON.parse(Buffer.from(part, 'base64url').toString('utf8')) as { exp?: number }
+    if (!json.exp) return null
+    return new Date(json.exp * 1000).toISOString()
+  } catch {
+    return null
+  }
+}
+
+/**
+ * Login contra el servidor online del juego (mismo /api/login-game que el PWA).
+ * El JWT se guarda cifrado; el renderer solo ve { username, role, serverUrl }.
+ */
+export class AuthService {
+  async login(request: AdminLoginRequest): Promise<AdminLoginResult> {
+    const username = (request.username || '').trim()
+    const password = request.password || ''
+    const serverUrl = (request.serverUrl || DEFAULT_SERVER).replace(/\/$/, '')
+    if (!username || !password) {
+      return { ok: false, error: 'Usuario y contraseña obligatorios' }
+    }
+
+    try {
+      const r = await fetch(serverUrl + '/api/login-game', {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json' },
+        body: JSON.stringify({
+          usuario: username,
+          username,
+          clave: password,
+          password
+        })
+      })
+      const data = (await r.json().catch(() => ({}))) as {
+        ok?: boolean
+        token?: string
+        error?: string
+        player?: { name?: string; nombre?: string }
+        user?: { username?: string; role?: string }
+        role?: string
+      }
+
+      if (!r.ok || !data.ok || !data.token) {
+        return {
+          ok: false,
+          error:
+            data.error ||
+            (r.status === 401 || r.status === 403
+              ? 'Usuario o contraseña incorrectos'
+              : 'No se pudo iniciar sesión (HTTP ' + r.status + ')')
+        }
+      }
+
+      const role = String(data.user?.role || data.role || 'jugador')
+      const session: PrivateSession = {
+        token: data.token,
+        username: data.user?.username || data.player?.name || data.player?.nombre || username,
+        role,
+        serverUrl,
+        expiresAt: decodeJwtExp(data.token),
+        loggedInAt: new Date().toISOString()
+      }
+      adminSessionStore.save(session)
+      return { ok: true, session: toPublic(session) }
+    } catch (error) {
+      const message = error instanceof Error ? error.message : 'Sin conexión con el servidor'
+      return { ok: false, error: 'Sin conexión: ' + message }
+    }
+  }
+
+  logout(): void {
+    adminSessionStore.clear()
+  }
+
+  getSession(): AdminSessionPublic | null {
+    const s = adminSessionStore.load()
+    if (!s) return null
+    if (s.expiresAt && Date.parse(s.expiresAt) < Date.now() - 60_000) {
+      adminSessionStore.clear()
+      return null
+    }
+    return toPublic(s)
+  }
+
+  /** Cabeceras Authorization listas para publish — null si no hay sesión. */
+  authHeaders(): Record<string, string> | null {
+    const token = adminSessionStore.getToken()
+    if (!token) return null
+    return {
