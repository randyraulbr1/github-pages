diff --git a/src/main/auth/sessionStore.ts b/src/main/auth/sessionStore.ts
new file mode 100644
index 0000000..3f7d2c0
--- /dev/null
+++ b/src/main/auth/sessionStore.ts
@@ -0,0 +1,85 @@
+import { app, safeStorage } from 'electron'
+import fs from 'node:fs'
+import path from 'node:path'
+import type { AdminSessionPublic } from '@shared-types/auth'
+
+const DEFAULT_SERVER = 'https://mariel-online.onrender.com'
+const FILE_NAME = 'admin-session.bin'
+
+interface PrivateSession {
+  token: string
+  username: string
+  role: string
+  serverUrl: string
+  expiresAt: string | null
+  loggedInAt: string
+}
+
+function sessionPath(): string {
+  return path.join(app.getPath('userData'), FILE_NAME)
+}
+
+function encode(session: PrivateSession): Buffer {
+  const json = Buffer.from(JSON.stringify(session), 'utf8')
+  if (safeStorage.isEncryptionAvailable()) {
+    return safeStorage.encryptString(json.toString('utf8'))
+  }
+  return json
+}
+
+function decode(buf: Buffer): PrivateSession | null {
+  try {
+    const raw = safeStorage.isEncryptionAvailable()
+      ? safeStorage.decryptString(buf)
+      : buf.toString('utf8')
+    return JSON.parse(raw) as PrivateSession
+  } catch {
+    return null
+  }
+}
+
+function toPublic(session: PrivateSession): AdminSessionPublic {
+  return {
+    username: session.username,
+    role: session.role,
+    serverUrl: session.serverUrl,
+    expiresAt: session.expiresAt,
+    loggedInAt: session.loggedInAt
+  }
+}
+
+/** Persistencia cifrada de la sesión admin (token sólo en main). */
+export class AdminSessionStore {
+  load(): PrivateSession | null {
+    const file = sessionPath()
+    if (!fs.existsSync(file)) return null
+    const buf = fs.readFileSync(file)
+    return decode(buf)
+  }
+
+  save(session: PrivateSession): void {
+    fs.writeFileSync(sessionPath(), encode(session))
+  }
+
+  clear(): void {
+    const file = sessionPath()
+    if (fs.existsSync(file)) fs.unlinkSync(file)
+  }
+
+  getPublic(): AdminSessionPublic | null {
+    const s = this.load()
+    return s ? toPublic(s) : null
+  }
+
+  getToken(): string | null {
+    return this.load()?.token ?? null
+  }
+
+  getServerUrl(): string {
+    return this.load()?.serverUrl || DEFAULT_SERVER
+  }
+}
+
+export const adminSessionStore = new AdminSessionStore()
+export { DEFAULT_SERVER, toPublic }
+export type { PrivateSession }
