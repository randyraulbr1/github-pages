+import { useState } from 'react'
+import type { WorldEntity } from '@shared-types/world'
+import { WorldSyncStatus } from '@shared-types/world'
+
+interface SyncPinMenuProps {
+  entity: WorldEntity
+  screen: { x: number; y: number }
+  onClose(): void
+  onChanged(): void
+}
+
+/**
+ * Menú al hacer clic en la bolita de estado del pin:
+ * gris → Subir | verde → Ver / Resync | rojo → Reintentar / Ver error
+ */
+export function SyncPinMenu({ entity, screen, onClose, onChanged }: SyncPinMenuProps): JSX.Element {
+  const [busy, setBusy] = useState(false)
+  const [message, setMessage] = useState<string | null>(null)
+  const status = entity.syncStatus
+
+  const isGrey =
+    status === WorldSyncStatus.Local ||
+    status === WorldSyncStatus.Pending ||
+    status === WorldSyncStatus.Offline ||
+    status === WorldSyncStatus.DeletedPending
+  const isGreen = status === WorldSyncStatus.Synced || status === WorldSyncStatus.Deleted
+  const isRed = status === WorldSyncStatus.Failed || status === WorldSyncStatus.Conflict
+  const isBusyStatus = status === WorldSyncStatus.Syncing || status === WorldSyncStatus.Deleting
+
+  const upload = async (): Promise<void> => {
+    setBusy(true)
+    setMessage(null)
+    try {
+      await window.api.worldEditor.enqueueEntity(entity.worldId)
+      const result = await window.api.worldEditor.publishChanges({
+        publishAll: false,
+        selectedWorldIds: [entity.worldId]
+      })
+      if (result.failed > 0) {
+        const fresh = await window.api.worldEditor.getEntity(entity.worldId)
+        setMessage(fresh?.lastSyncError || 'Falló la subida')
+      } else if (result.published === 0) {
+        setMessage('Nada que subir — inicia sesión si aún no lo has hecho')
+      } else {
+        setMessage('Subido al mundo online')
+      }
+      onChanged()
+    } catch (error) {
+      setMessage(error instanceof Error ? error.message : 'Error al subir')
+    } finally {
+      setBusy(false)
+    }
+  }
+
+  return (
+    <div
+      className="absolute z-[1200] min-w-[200px] rounded-md border border-surface-border bg-surface-1 py-1 text-xs shadow-xl"
+      style={{ left: screen.x, top: screen.y }}
+      onClick={(event) => event.stopPropagation()}
+    >
+      <div className="border-b border-surface-border px-3 py-1.5 text-[10px] uppercase tracking-wide text-slate-500">
+        Sync · {entity.name}
+      </div>
+      <div className="px-3 py-1 text-slate-400">
+        Estado: <span className="text-slate-200">{status}</span>
+      </div>
+      {entity.lastSyncError && (
+        <div className="max-w-[260px] whitespace-pre-wrap break-words px-3 py-1 text-red-400">
+          {entity.lastSyncError}
+        </div>
+      )}
+      {message && <div className="px-3 py-1 text-amber-300">{message}</div>}
+
+      <div className="mt-1 flex flex-col">
+        {(isGrey || isBusyStatus) && (
+          <button
+            type="button"
+            disabled={busy}
+            onClick={() => void upload()}
+            className="px-3 py-1.5 text-left hover:bg-surface-2 disabled:opacity-50"
+          >
+            Subir al mundo
+          </button>
+        )}
+        {isGreen && (
+          <>
+            <button
+              type="button"
+              onClick={() => setMessage(entity.lastSyncError || 'Sincronizado con el juego online')}
+              className="px-3 py-1.5 text-left hover:bg-surface-2"
+            >
+              Ver estado
+            </button>
+            <button
+              type="button"
+              disabled={busy}
+              onClick={() => void upload()}
+              className="px-3 py-1.5 text-left hover:bg-surface-2 disabled:opacity-50"
+            >
+              Volver a sincronizar
+            </button>
+          </>
+        )}
+        {isRed && (
+          <>
+            <button
+              type="button"
+              onClick={() => setMessage(entity.lastSyncError || 'Error desconocido')}
+              className="px-3 py-1.5 text-left hover:bg-surface-2"
+            >
+              Ver error
+            </button>
+            <button
+              type="button"
+              disabled={busy}
+              onClick={() => void upload()}
+              className="px-3 py-1.5 text-left hover:bg-surface-2 disabled:opacity-50"
+            >
+              Reintentar
+            </button>
+          </>
+        )}
+        <button type="button" onClick={onClose} className="px-3 py-1.5 text-left text-slate-500 hover:bg-surface-2">
+          Cerrar
+        </button>
+      </div>
+    </div>
+  )
+}
