@@ -0,0 +1,122 @@
+import { useEffect, useState } from 'react'
+import { LogIn, LogOut, UserRound } from 'lucide-react'
+import type { AdminSessionPublic } from '@shared-types/auth'
+
+/**
+ * Login / sesión del administrador en la barra de título.
+ * No muestra tokens: solo usuario + servidor.
+ */
+export function AdminSessionButton(): JSX.Element {
+  const [session, setSession] = useState<AdminSessionPublic | null>(null)
+  const [open, setOpen] = useState(false)
+  const [username, setUsername] = useState('')
+  const [password, setPassword] = useState('')
+  const [error, setError] = useState<string | null>(null)
+  const [busy, setBusy] = useState(false)
+
+  const refresh = async (): Promise<void> => {
+    const s = await window.api.auth.getSession()
+    setSession(s)
+  }
+
+  useEffect(() => {
+    void refresh()
+  }, [])
+
+  const login = async (): Promise<void> => {
+    setBusy(true)
+    setError(null)
+    try {
+      const result = await window.api.auth.login({ username, password })
+      if (!result.ok || !result.session) {
+        setError(result.error || 'No se pudo iniciar sesión')
+        return
+      }
+      setSession(result.session)
+      setPassword('')
+      setOpen(false)
+    } finally {
+      setBusy(false)
+    }
+  }
+
+  const logout = async (): Promise<void> => {
+    await window.api.auth.logout()
+    setSession(null)
+  }
+
+  return (
+    <div className="relative mr-2 flex items-center">
+      <button
+        type="button"
+        onClick={() => setOpen((v) => !v)}
+        className="flex items-center gap-1.5 rounded px-2 py-1 text-xs text-slate-300 hover:bg-surface-2"
+        title={session ? `Sesión: ${session.username}` : 'Iniciar sesión de administrador'}
+      >
+        {session ? <UserRound size={12} className="text-emerald-400" /> : <LogIn size={12} />}
+        <span className="max-w-[120px] truncate">
+          {session ? session.username : 'Iniciar sesión'}
+        </span>
+      </button>
+
+      {open && (
+        <div className="absolute right-0 top-full z-[2000] mt-1 w-72 rounded-md border border-surface-border bg-surface-1 p-3 shadow-xl">
+          {session ? (
+            <div className="space-y-2 text-xs">
+              <div className="font-medium text-slate-200">{session.username}</div>
+              <div className="text-slate-500">Rol: {session.role}</div>
+              <div className="truncate text-slate-500" title={session.serverUrl}>
+                Servidor: {session.serverUrl.replace(/^https?:\/\//, '')}
+              </div>
+              {session.expiresAt && Date.parse(session.expiresAt) < Date.now() && (
+                <div className="rounded bg-red-950/40 px-2 py-1 text-[11px] text-red-300">
+                  La sesión ha expirado. Vuelve a iniciar sesión para publicar.
+                </div>
+              )}
+              <button
+                type="button"
+                onClick={() => void logout()}
+                className="mt-2 flex w-full items-center justify-center gap-1 rounded bg-surface-2 px-2 py-1.5 hover:bg-surface-0"
+              >
+                <LogOut size={12} /> Cerrar sesión
+              </button>
+            </div>
+          ) : (
+            <form
+              className="space-y-2"
+              onSubmit={(event) => {
+                event.preventDefault()
+                void login()
+              }}
+            >
+              <div className="text-xs font-medium text-slate-200">Administrador del juego</div>
+              <input
+                value={username}
+                onChange={(e) => setUsername(e.target.value)}
+                placeholder="Usuario"
+                className="w-full rounded border border-surface-border bg-surface-2 px-2 py-1.5 text-xs outline-none focus:border-accent"
+                autoComplete="username"
+              />
+              <input
+                type="password"
+                value={password}
+                onChange={(e) => setPassword(e.target.value)}
+                placeholder="Contraseña"
+                className="w-full rounded border border-surface-border bg-surface-2 px-2 py-1.5 text-xs outline-none focus:border-accent"
+                autoComplete="current-password"
+              />
+              {error && <div className="text-[11px] text-red-400">{error}</div>}
+              <button
+                type="submit"
+                disabled={busy}
+                className="w-full rounded bg-accent px-2 py-1.5 text-xs font-medium text-white hover:bg-accent-hover disabled:opacity-60"
+              >
+                {busy ? 'Conectando…' : 'Entrar'}
+              </button>
+            </form>
+          )}
+        </div>
+      )}
+    </div>
+  )
+}
