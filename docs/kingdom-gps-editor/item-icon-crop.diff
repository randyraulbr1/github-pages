diff --git a/src/renderer/src/modules/items/components/IconCropPicker.tsx b/src/renderer/src/modules/items/components/IconCropPicker.tsx
new file mode 100644
index 0000000..e12b17d
--- /dev/null
+++ b/src/renderer/src/modules/items/components/IconCropPicker.tsx
@@ -0,0 +1,197 @@
+import { useCallback, useEffect, useRef, useState } from 'react'
+import type { IconCrop } from '@shared-types/item'
+import { normalizeIconCrop } from '@shared-types/item'
+import { useIcon } from '@renderer/shared/hooks/useIconPath'
+import { IconThumbnail } from '@renderer/shared/components/IconThumbnail'
+
+interface IconCropPickerProps {
+  iconId: number
+  initialCrop: IconCrop | null
+  onApply(crop: IconCrop | null): void
+  onClose(): void
+}
+
+type DragPoint = { x: number; y: number }
+
+/**
+ * Selector de región sobre la imagen completa del icono.
+ * Arrastra para marcar el recorte; Shift mantiene cuadrado.
+ */
+export function IconCropPicker({ iconId, initialCrop, onApply, onClose }: IconCropPickerProps): JSX.Element {
+  const icon = useIcon(iconId)
+  const imgRef = useRef<HTMLImageElement>(null)
+  const [natural, setNatural] = useState({ w: icon?.width ?? 0, h: icon?.height ?? 0 })
+  const [draft, setDraft] = useState<IconCrop | null>(initialCrop)
+  const [dragStart, setDragStart] = useState<DragPoint | null>(null)
+  const [dragCurrent, setDragCurrent] = useState<DragPoint | null>(null)
+
+  useEffect(() => {
+    setDraft(initialCrop)
+  }, [initialCrop, iconId])
+
+  const toImageCoords = useCallback(
+    (clientX: number, clientY: number): DragPoint | null => {
+      const el = imgRef.current
+      if (!el || natural.w <= 0 || natural.h <= 0) return null
+      const rect = el.getBoundingClientRect()
+      const x = ((clientX - rect.left) / rect.width) * natural.w
+      const y = ((clientY - rect.top) / rect.height) * natural.h
+      return {
+        x: Math.max(0, Math.min(natural.w, x)),
+        y: Math.max(0, Math.min(natural.h, y))
+      }
+    },
+    [natural]
+  )
+
+  const selectionFromDrag = (a: DragPoint, b: DragPoint, square: boolean): IconCrop | null => {
+    let x1 = Math.min(a.x, b.x)
+    let y1 = Math.min(a.y, b.y)
+    let w = Math.abs(a.x - b.x)
+    let h = Math.abs(a.y - b.y)
+    if (square) {
+      const side = Math.max(w, h)
+      if (b.x < a.x) x1 = a.x - side
+      if (b.y < a.y) y1 = a.y - side
+      w = side
+      h = side
+    }
+    x1 = Math.max(0, x1)
+    y1 = Math.max(0, y1)
+    w = Math.min(w, natural.w - x1)
+    h = Math.min(h, natural.h - y1)
+    return normalizeIconCrop({ x: x1, y: y1, width: w, height: h })
+  }
+
+  const liveCrop =
+    dragStart && dragCurrent ? selectionFromDrag(dragStart, dragCurrent, false) : draft
+
+  if (!icon?.relativePath) {
+    return (
+      <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/70 p-4">
+        <div className="rounded-lg bg-surface-2 p-6 text-sm text-slate-300">Cargando imagen…</div>
+      </div>
+    )
+  }
+
+  const src = `kgps-icon://${icon.relativePath}`
+  const displayCrop = liveCrop
+
+  return (
+    <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/70 p-4" onClick={onClose}>
+      <div
+        className="flex max-h-[90vh] w-full max-w-3xl flex-col gap-4 overflow-hidden rounded-lg border border-surface-border bg-surface-1 p-4 shadow-xl"
+        onClick={(event) => event.stopPropagation()}
+      >
+        <div className="flex items-start justify-between gap-3">
+          <div>
+            <h2 className="text-sm font-semibold text-slate-100">Recortar icono del objeto</h2>
+            <p className="mt-1 text-xs text-slate-500">
+              Arrastra sobre la imagen para elegir la zona. Mantén Shift para forzar cuadrado.
+            </p>
+          </div>
+          <button
+            type="button"
+            onClick={onClose}
+            className="rounded px-2 py-1 text-xs text-slate-400 hover:bg-surface-2 hover:text-slate-200"
+          >
+            ✕
+          </button>
+        </div>
+
+        <div className="flex flex-wrap items-start gap-4">
+          <div className="max-h-[60vh] flex-1 overflow-auto rounded border border-surface-border bg-surface-2 p-2">
+            <div className="relative inline-block max-w-full">
+              <img
+                ref={imgRef}
+                src={src}
+                alt={icon.fileName}
+                className="block max-h-[55vh] max-w-full select-none"
+                draggable={false}
+                onLoad={(event) => {
+                  const img = event.currentTarget
+                  setNatural({ w: img.naturalWidth || icon.width, h: img.naturalHeight || icon.height })
+                }}
+                onMouseDown={(event) => {
+                  const p = toImageCoords(event.clientX, event.clientY)
+                  if (!p) return
+                  event.preventDefault()
+                  setDragStart(p)
+                  setDragCurrent(p)
+                }}
+                onMouseMove={(event) => {
+                  if (!dragStart) return
+                  const p = toImageCoords(event.clientX, event.clientY)
+                  if (p) setDragCurrent(p)
+                }}
+                onMouseUp={(event) => {
+                  if (!dragStart) return
+                  const p = toImageCoords(event.clientX, event.clientY) || dragCurrent
+                  if (p) setDraft(selectionFromDrag(dragStart, p, event.shiftKey))
+                  setDragStart(null)
+                  setDragCurrent(null)
+                }}
+                onMouseLeave={() => {
+                  if (dragStart && dragCurrent) {
+                    setDraft(selectionFromDrag(dragStart, dragCurrent, false))
+                  }
+                  setDragStart(null)
+                  setDragCurrent(null)
+                }}
+              />
+              {displayCrop && natural.w > 0 && natural.h > 0 && (
+                <div
+                  className="pointer-events-none absolute border-2 border-accent bg-accent/20"
+                  style={{
+                    left: `${(displayCrop.x / natural.w) * 100}%`,
+                    top: `${(displayCrop.y / natural.h) * 100}%`,
+                    width: `${(displayCrop.width / natural.w) * 100}%`,
+                    height: `${(displayCrop.height / natural.h) * 100}%`
+                  }}
+                />
+              )}
+            </div>
+          </div>
+
+          <div className="flex w-40 flex-col items-center gap-3">
+            <div className="text-[10px] uppercase tracking-wide text-slate-500">Vista previa</div>
+            <IconThumbnail iconId={iconId} crop={displayCrop} size={96} />
+            {displayCrop ? (
+              <div className="text-center text-[10px] text-slate-500">
+                {displayCrop.width}×{displayCrop.height}px
+                <br />
+                @ ({displayCrop.x}, {displayCrop.y})
+              </div>
+            ) : (
+              <div className="text-center text-[10px] text-slate-500">Imagen completa</div>
+            )}
+          </div>
+        </div>
+
+        <div className="flex flex-wrap justify-end gap-2 border-t border-surface-border pt-3">
+          <button
+            type="button"
+            onClick={() => onApply(null)}
+            className="rounded-md border border-surface-border px-3 py-1.5 text-xs text-slate-300 hover:bg-surface-2"
+          >
+            Usar imagen completa
+          </button>
+          <button
+            type="button"
+            onClick={onClose}
+            className="rounded-md border border-surface-border px-3 py-1.5 text-xs text-slate-300 hover:bg-surface-2"
+          >
+            Cancelar
+          </button>
+          <button
+            type="button"
+            onClick={() => onApply(draft)}
+            className="rounded-md bg-accent px-3 py-1.5 text-xs font-medium text-white hover:bg-accent-hover"
+          >
+            Aplicar recorte
+          </button>
+        </div>
+      </div>
+    </div>
+  )
+}
