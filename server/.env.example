PORT=3000
NODE_ENV=production
JWT_SECRET=cambia-este-secreto-en-produccion
TRUST_PROXY=1
SYNC_INTERVAL_MS=12000

# Orígenes CORS (Oracle Nginx + rollback GitHub Pages)
CORS_ORIGINS=https://tcodm.com,https://www.tcodm.com,https://api.tcodm.com,https://randyraulbr1.github.io

# Respaldo permanente en GitHub (PAT contents:write) — backup, no runtime
GITHUB_TOKEN=
GITHUB_REPO=randyraulbr1/github-pages
GITHUB_BRANCH=main

GAME_ADMIN_NAME=SoyCaos
GAME_ADMIN_ALIASES=randy

# Opcional: POST /api/public/import-jugadores
IMPORT_SECRET=

# SQLite (persistente en Oracle VM)
# DATABASE_DIR=/home/ubuntu/github-pages/server/data
