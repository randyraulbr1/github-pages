//@version=5
strategy(
     title             = "BG $200k XAUUSD - BOS/CHoCH Strategy",
     shorttitle        = "BG-BOS",
     overlay           = true,
     initial_capital   = 200000,
     default_qty_type  = strategy.fixed,
     default_qty_value = 50,
     commission_type   = strategy.commission.cash_per_contract,
     commission_value  = 0.50,
     currency          = currency.USD,
     process_orders_on_close = true,   // ejecuta en cierre de barra, menos slippage
     max_bars_back     = 500)

// ═══════════════════════════════════════════════════════════════════
//  INPUTS
// ═══════════════════════════════════════════════════════════════════
grp1 = "Estructura de Mercado"
pivot_len   = input.int(3,     "Pivot Length",         minval=2, maxval=8,   group=grp1)
atr_mult    = input.float(1.2, "ATR Multiplier (SL)",  minval=0.5, step=0.1, group=grp1)
min_rr      = input.float(2.5, "Risk:Reward minimo",   minval=1.5, step=0.5, group=grp1)
pivot_bars  = input.int(96,    "Ventana pivot (barras)",minval=20, maxval=200,group=grp1)

grp2 = "Blue Guardian Rules"
daily_loss_lim = input.float(6000,  "Daily Loss Limit ($)",   group=grp2)
guard_shield   = input.float(2000,  "Guardian Shield ($)",    group=grp2)
trail_dd_lim   = input.float(12000, "Trail Max Drawdown ($)", group=grp2)
// Reducimos a $35/oz para absorber slippage y quedar bajo $2000
max_risk_oz    = input.float(35.0,  "Max riesgo por oz ($) — incluye slippage", group=grp2)

grp3 = "Sesiones (UTC)"
london_on = input.bool(true, "Londres 07-12 UTC", group=grp3)
ny_on     = input.bool(true, "NY 13-18 UTC",      group=grp3)

grp4 = "Filtro HTF"
htf_tf     = input.timeframe("240", "Timeframe RSI HTF", group=grp4)
rsi_period = input.int(14, "RSI Period", group=grp4)
rsi_thresh = input.float(50, "RSI umbral", minval=40, maxval=60, group=grp4)

// ═══════════════════════════════════════════════════════════════════
//  SESION & NOTICIAS
// ═══════════════════════════════════════════════════════════════════
in_london  = hour >= 7  and hour < 12
in_ny      = hour >= 13 and hour < 18
in_session = (london_on and in_london) or (ny_on and in_ny)

nd(y, m, d) => year == y and month == m and dayofmonth == d

is_news = nd(2024,1,5)  or nd(2024,1,11) or nd(2024,2,2)  or nd(2024,3,20) or
          nd(2024,4,10) or nd(2024,5,1)  or nd(2024,6,12) or nd(2024,7,31) or
          nd(2024,9,18) or nd(2024,11,7) or nd(2024,12,18) or nd(2025,1,29) or
          nd(2025,3,19) or nd(2025,4,30) or nd(2025,5,7)  or nd(2025,6,6)

is_wknd       = dayofweek == dayofweek.saturday or dayofweek == dayofweek.sunday
trade_allowed = in_session and not is_news and not is_wknd

// ═══════════════════════════════════════════════════════════════════
//  INDICADORES
// ═══════════════════════════════════════════════════════════════════
rsi_htf  = request.security(syminfo.tickerid, htf_tf, ta.rsi(close, rsi_period), lookahead=barmerge.lookahead_off)
atr_val  = ta.atr(14)

// Pivots — confirmados pivot_len barras después
ph = ta.pivothigh(high, pivot_len, pivot_len)
pl = ta.pivotlow(low,   pivot_len, pivot_len)

var float last_ph     = na
var float last_pl     = na
var int   last_ph_bar = 0
var int   last_pl_bar = 0

// Actualizamos SIEMPRE (no solo en sesión) para no perder pivots
if not na(ph)
    last_ph     := ph
    last_ph_bar := bar_index - pivot_len

if not na(pl)
    last_pl     := pl
    last_pl_bar := bar_index - pivot_len

// Ventana ampliada a pivot_bars (default 96) para más señales
ph_ok = not na(last_ph) and (bar_index - last_ph_bar) <= pivot_bars
pl_ok = not na(last_pl) and (bar_index - last_pl_bar) <= pivot_bars

// ═══════════════════════════════════════════════════════════════════
//  MAX 2 TRADES POR DIA
// ═══════════════════════════════════════════════════════════════════
var int trades_today = 0
new_day = ta.change(dayofmonth) != 0 or ta.change(month) != 0

if new_day
    trades_today := 0

can_trade  = trades_today < 2
no_pos     = strategy.position_size == 0

// ═══════════════════════════════════════════════════════════════════
//  SEÑALES BOS
//  Condición más permisiva: solo necesita romper el pivot (sin buffer %)
// ═══════════════════════════════════════════════════════════════════
bos_long  = ph_ok and pl_ok and close > last_ph and rsi_htf > rsi_thresh and trade_allowed and can_trade and no_pos
bos_short = ph_ok and pl_ok and close < last_pl and rsi_htf < rsi_thresh and trade_allowed and can_trade and no_pos

// ═══════════════════════════════════════════════════════════════════
//  SL / TP — con cap duro para Guardian Shield
// ═══════════════════════════════════════════════════════════════════
// LONG: SL debajo del pivot low + buffer ATR
long_sl_base = last_pl - atr_val * atr_mult
long_risk_b  = close - long_sl_base
// Si el riesgo supera max_risk_oz, acercamos el SL
long_sl      = long_risk_b > max_risk_oz ? close - max_risk_oz : long_sl_base
long_risk    = close - long_sl
long_tp      = close + long_risk * min_rr

// SHORT: SL encima del pivot high + buffer ATR
short_sl_base = last_ph + atr_val * atr_mult
short_risk_b  = short_sl_base - close
short_sl      = short_risk_b > max_risk_oz ? close + max_risk_oz : short_sl_base
short_risk    = short_sl - close
short_tp      = close - short_risk * min_rr

// ═══════════════════════════════════════════════════════════════════
//  BLUE GUARDIAN — TRACKING
// ═══════════════════════════════════════════════════════════════════
var float day_start_eq = strategy.equity
var float daily_pnl    = 0.0

if new_day
    day_start_eq := strategy.equity
    daily_pnl    := 0.0
else
    daily_pnl := strategy.equity - day_start_eq

var float eq_peak = strategy.equity
eq_peak := math.max(eq_peak, strategy.equity)

trail_dd      = eq_peak - strategy.equity
guardian_ok   = daily_pnl > -guard_shield
trail_ok      = trail_dd < trail_dd_lim
daily_ok      = daily_pnl > -daily_loss_lim
bg_ok         = guardian_ok and trail_ok and daily_ok

// Cierre de emergencia si se viola trail DD con posicion abierta
if not trail_ok and not no_pos
    strategy.close_all(comment="Trail DD Breach")

if not daily_ok and not no_pos
    strategy.close_all(comment="Daily Loss Limit")

// ═══════════════════════════════════════════════════════════════════
//  ENTRADAS
// ═══════════════════════════════════════════════════════════════════
if bos_long and bg_ok and long_risk > 3
    strategy.entry("L", strategy.long,  qty=50, comment="BOS+")
    strategy.exit("XL", "L", stop=long_sl,  limit=long_tp)
    trades_today := trades_today + 1

if bos_short and bg_ok and short_risk > 3
    strategy.entry("S", strategy.short, qty=50, comment="BOS-")
    strategy.exit("XS", "S", stop=short_sl, limit=short_tp)
    trades_today := trades_today + 1

// ═══════════════════════════════════════════════════════════════════
//  VISUALIZACION
// ═══════════════════════════════════════════════════════════════════
// Lineas de pivots activos
plot(ph_ok ? last_ph : na, "Ultimo PH", color=color.new(color.red,   50), style=plot.style_linebr, linewidth=1)
plot(pl_ok ? last_pl : na, "Ultimo PL", color=color.new(color.green, 50), style=plot.style_linebr, linewidth=1)

// Marcadores en pivots nuevos
plotshape(not na(ph), style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.tiny,  title="PH")
plotshape(not na(pl), style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.tiny,  title="PL")

// Señales BOS
plotshape(bos_long,  style=shape.labelup,   location=location.belowbar, color=color.lime, textcolor=color.black, text="BOS+", size=size.normal, title="BOS Long")
plotshape(bos_short, style=shape.labeldown, location=location.abovebar, color=color.red,  textcolor=color.white, text="BOS-", size=size.normal, title="BOS Short")

// Fondo de sesiones
bgcolor(in_london and london_on ? color.new(color.blue,   93) : na, title="Londres")
bgcolor(in_ny     and ny_on     ? color.new(color.orange, 93) : na, title="NY")
bgcolor(is_news                 ? color.new(color.red,    85) : na, title="Noticias")

// ═══════════════════════════════════════════════════════════════════
//  TABLA BLUE GUARDIAN
// ═══════════════════════════════════════════════════════════════════
var table t = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 60), border_color=color.new(color.gray,40), border_width=1, frame_width=1)

c_ok  = color.new(color.green, 25)
c_bad = color.new(color.red,   25)
c_neu = color.new(color.gray,  40)
c_hdr = color.new(color.navy,  20)

if barstate.islast
    table.cell(t, 0, 0, "BLUE GUARDIAN",      text_color=color.white, bgcolor=c_hdr, text_size=size.small)
    table.cell(t, 1, 0, "Cuenta $200k",       text_color=color.white, bgcolor=c_hdr, text_size=size.small)

    table.cell(t, 0, 1, "Daily P&L",          text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 1, str.tostring(math.round(daily_pnl)) + " USD",
         bgcolor=daily_pnl >= 0 ? c_ok : not daily_ok ? c_bad : c_neu,
         text_color=color.white, text_size=size.tiny)

    table.cell(t, 0, 2, "Guardian Shield",    text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 2, guardian_ok ? "OK  " : "VIOLADO",
         bgcolor=guardian_ok ? c_ok : c_bad, text_color=color.white, text_size=size.tiny)

    table.cell(t, 0, 3, "Trail Drawdown",     text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 3, str.tostring(math.round(trail_dd)) + " / 12000",
         bgcolor=trail_ok ? c_ok : c_bad, text_color=color.white, text_size=size.tiny)

    table.cell(t, 0, 4, "Trades Hoy",         text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 4, str.tostring(trades_today) + " / 2",
         bgcolor=can_trade ? c_ok : c_bad, text_color=color.white, text_size=size.tiny)

    table.cell(t, 0, 5, "Equity",             text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 5, str.tostring(math.round(strategy.equity)) + " USD",
         bgcolor=strategy.equity >= 205000 ? c_ok : c_neu, text_color=color.white, text_size=size.tiny)

    table.cell(t, 0, 6, "Sesion Activa",      text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 6, in_session ? (in_london ? "Londres" : "NY") : "Cerrada",
         bgcolor=in_session ? c_ok : c_neu, text_color=color.white, text_size=size.tiny)
