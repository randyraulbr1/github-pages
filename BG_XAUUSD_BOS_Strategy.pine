//@version=5
strategy("BG $200k XAUUSD - BOS Strategy", "BG-BOS", overlay=true,
     initial_capital=200000, default_qty_type=strategy.fixed, default_qty_value=50,
     commission_type=strategy.commission.cash_per_contract, commission_value=0.5,
     currency=currency.USD, process_orders_on_close=true, max_bars_back=500)

// ── INPUTS ──────────────────────────────────────────────────────────
i_pivot   = input.int(3,    "Pivot Length",      minval=2, maxval=8)
i_atr     = input.float(1.2,"ATR Mult SL",       minval=0.5, step=0.1)
i_rr      = input.float(2.5,"Risk:Reward",       minval=1.5, step=0.5)
i_maxrisk = input.float(35, "Max riesgo/oz (USD)",minval=10,  step=5)
i_london  = input.bool(true, "Sesion Londres 07-12 UTC")
i_ny      = input.bool(true, "Sesion NY 13-18 UTC")
i_rsi_tf  = input.timeframe("240","RSI Timeframe HTF")
i_rsi_p   = input.int(14,  "RSI Period")

// ── SESION ───────────────────────────────────────────────────────────
london    = i_london and (hour >= 7  and hour < 12)
ny        = i_ny     and (hour >= 13 and hour < 18)
in_sess   = london or ny

// ── NOTICIAS (NFP / CPI / FOMC) ──────────────────────────────────────
nd(m,d) => month == m and dayofmonth == d
news = nd(1,10) or nd(1,15) or nd(1,29) or nd(2,7)  or nd(2,12) or nd(2,26) or
       nd(3,7)  or nd(3,12) or nd(3,19) or nd(4,4)  or nd(4,10) or nd(4,30) or
       nd(5,2)  or nd(5,7)  or nd(5,13) or nd(6,6)  or nd(6,18)

// ── INDICADORES ───────────────────────────────────────────────────────
rsi_htf  = request.security(syminfo.tickerid, i_rsi_tf, ta.rsi(close, i_rsi_p), lookahead=barmerge.lookahead_off)
atr_v    = ta.atr(14)
ph       = ta.pivothigh(high, i_pivot, i_pivot)
pl       = ta.pivotlow (low,  i_pivot, i_pivot)

var float last_ph = na
var float last_pl = na
var int   ph_bar  = 0
var int   pl_bar  = 0

if not na(ph) => last_ph := ph, ph_bar := bar_index - i_pivot
if not na(pl) => last_pl := pl, pl_bar := bar_index - i_pivot

ph_ok = not na(last_ph) and bar_index - ph_bar <= 96
pl_ok = not na(last_pl) and bar_index - pl_bar <= 96

// ── BLUE GUARDIAN TRACKING ────────────────────────────────────────────
var float day_eq0  = strategy.equity
var float eq_peak  = strategy.equity
var int   day_tr   = 0
new_day = ta.change(dayofmonth) != 0

if new_day
    day_eq0 := strategy.equity
    day_tr  := 0

eq_peak    := math.max(eq_peak, strategy.equity)
daily_pnl   = strategy.equity - day_eq0
trail_dd    = eq_peak - strategy.equity
guardian_ok = daily_pnl > -2000
trail_ok    = trail_dd  < 12000
daily_ok    = daily_pnl > -6000
bg_ok       = guardian_ok and trail_ok and daily_ok and day_tr < 2

// ── SEÑALES BOS ───────────────────────────────────────────────────────
no_pos = strategy.position_size == 0
allow  = in_sess and not news and bg_ok and no_pos

bos_l = allow and ph_ok and pl_ok and close > last_ph and rsi_htf > 50
bos_s = allow and ph_ok and pl_ok and close < last_pl and rsi_htf < 50

// ── SL / TP ───────────────────────────────────────────────────────────
l_sl_r = last_pl - atr_v * i_atr
l_risk = close - l_sl_r
l_sl   = l_risk > i_maxrisk ? close - i_maxrisk : l_sl_r
l_tp   = close + (close - l_sl) * i_rr

s_sl_r = last_ph + atr_v * i_atr
s_risk = s_sl_r - close
s_sl   = s_risk > i_maxrisk ? close + i_maxrisk : s_sl_r
s_tp   = close - (s_sl - close) * i_rr

// ── ENTRADAS ──────────────────────────────────────────────────────────
if bos_l and (close - l_sl) > 3
    strategy.entry("L", strategy.long,  50, comment="BOS+")
    strategy.exit ("XL","L", stop=l_sl, limit=l_tp)
    day_tr += 1

if bos_s and (s_sl - close) > 3
    strategy.entry("S", strategy.short, 50, comment="BOS-")
    strategy.exit ("XS","S", stop=s_sl, limit=s_tp)
    day_tr += 1

// ── VISUALIZACION ─────────────────────────────────────────────────────
plot(ph_ok ? last_ph : na, "PH", color.new(color.red,   40), 1, plot.style_linebr)
plot(pl_ok ? last_pl : na, "PL", color.new(color.green, 40), 1, plot.style_linebr)

plotshape(not na(ph), style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.tiny)
plotshape(not na(pl), style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.tiny)
plotshape(bos_l, style=shape.labelup,   location=location.belowbar, color=color.lime, textcolor=color.black, text="BOS+", size=size.small)
plotshape(bos_s, style=shape.labeldown, location=location.abovebar, color=color.red,  textcolor=color.white, text="BOS-", size=size.small)

bgcolor(london ? color.new(color.blue,   93) : na, title="Londres")
bgcolor(ny     ? color.new(color.orange, 93) : na, title="NY")
bgcolor(news   ? color.new(color.red,    85) : na, title="Noticias")

// ── TABLA BG ──────────────────────────────────────────────────────────
var table t = table.new(position.top_right, 2, 6,
     bgcolor=color.new(color.black,55), border_color=color.new(color.gray,50), border_width=1)

if barstate.islast
    cg = color.new(color.green, 20)
    cr = color.new(color.red,   20)
    cn = color.new(color.gray,  35)
    ch = color.new(color.navy,  15)

    table.cell(t,0,0,"BLUE GUARDIAN",    text_color=color.white, bgcolor=ch, text_size=size.small)
    table.cell(t,1,0,"$200k XAUUSD",     text_color=color.gold,  bgcolor=ch, text_size=size.small)

    table.cell(t,0,1,"Daily P&L",        text_color=color.white, text_size=size.tiny)
    table.cell(t,1,1,str.tostring(math.round(daily_pnl))+" USD",
         bgcolor=daily_pnl>=0?cg:not daily_ok?cr:cn, text_color=color.white, text_size=size.tiny)

    table.cell(t,0,2,"Trail DD",         text_color=color.white, text_size=size.tiny)
    table.cell(t,1,2,str.tostring(math.round(trail_dd))+" / 12000",
         bgcolor=trail_ok?cg:cr, text_color=color.white, text_size=size.tiny)

    table.cell(t,0,3,"Guardian",         text_color=color.white, text_size=size.tiny)
    table.cell(t,1,3,guardian_ok?"OK":"ACTIVO", bgcolor=guardian_ok?cg:cr, text_color=color.white, text_size=size.tiny)

    table.cell(t,0,4,"Trades Hoy",       text_color=color.white, text_size=size.tiny)
    table.cell(t,1,4,str.tostring(day_tr)+" / 2", bgcolor=day_tr<2?cg:cr, text_color=color.white, text_size=size.tiny)

    table.cell(t,0,5,"Sesion",           text_color=color.white, text_size=size.tiny)
    table.cell(t,1,5,in_sess?(london?"Londres":"NY"):"Cerrada", bgcolor=in_sess?cg:cn, text_color=color.white, text_size=size.tiny)
