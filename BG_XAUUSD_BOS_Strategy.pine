//@version=5
indicator("BG XAUUSD Senales BOS", overlay=true, max_bars_back=500, max_lines_count=100, max_labels_count=100)

// INPUTS
p_len  = input.int(3,    "Pivot Length",       minval=2, maxval=6)
p_atr  = input.float(1.2,"ATR Mult SL",        minval=0.5, step=0.1)
p_rr   = input.float(2.5,"Risk Reward",        minval=1.5, step=0.5)
p_risk = input.float(40, "Max riesgo por oz",  minval=10,  step=5)
p_ema  = input.int(50,   "EMA Tendencia",      minval=10,  maxval=200)
p_lon  = input.bool(true,"Londres 07-12 UTC")
p_ny   = input.bool(true,"NY 13-18 UTC")

// SESION
lon     = p_lon and hour >= 7  and hour < 12
ny      = p_ny  and hour >= 13 and hour < 18
sesion  = lon or ny

// NOTICIAS
news = (month==1  and dayofmonth==10) or (month==1  and dayofmonth==15) or
       (month==1  and dayofmonth==29) or (month==2  and dayofmonth==7)  or
       (month==2  and dayofmonth==12) or (month==3  and dayofmonth==7)  or
       (month==3  and dayofmonth==12) or (month==3  and dayofmonth==19) or
       (month==4  and dayofmonth==4)  or (month==4  and dayofmonth==10) or
       (month==4  and dayofmonth==30) or (month==5  and dayofmonth==2)  or
       (month==5  and dayofmonth==7)  or (month==5  and dayofmonth==13) or
       (month==6  and dayofmonth==6)  or (month==6  and dayofmonth==18)

// INDICADORES
ema50   = ta.ema(close, p_ema)
atr_v   = ta.atr(14)
rsi4h   = request.security(syminfo.tickerid, "240", ta.rsi(close, 14), lookahead=barmerge.lookahead_off)

ph = ta.pivothigh(high, p_len, p_len)
pl = ta.pivotlow (low,  p_len, p_len)

var float lph = na
var float lpl = na
var int   bph = 0
var int   bpl = 0

if not na(ph)
    lph := ph
    bph := bar_index - p_len

if not na(pl)
    lpl := pl
    bpl := bar_index - p_len

ph_ok = not na(lph) and bar_index - bph <= 96
pl_ok = not na(lpl) and bar_index - bpl <= 96

// MAX 2 SENALES POR DIA
var int ds = 0
if ta.change(dayofmonth) != 0
    ds := 0

// SENALES BOS
ok     = sesion and not news and ds < 2
bos_l  = ok and ph_ok and pl_ok and close > lph and rsi4h > 50 and close > ema50
bos_s  = ok and ph_ok and pl_ok and close < lpl and rsi4h < 50 and close < ema50

if bos_l or bos_s
    ds += 1

// SL Y TP LONG
l_sl_r = lpl - atr_v * p_atr
l_risk = close - l_sl_r
l_sl   = l_risk > p_risk ? close - p_risk : l_sl_r
l_tp   = close + (close - l_sl) * p_rr

// SL Y TP SHORT
s_sl_r = lph + atr_v * p_atr
s_risk = s_sl_r - close
s_sl   = s_risk > p_risk ? close + p_risk : s_sl_r
s_tp   = close - (s_sl - close) * p_rr

// DIBUJAR LINEAS Y ETIQUETA
if bos_l and (close - l_sl) > 3
    ext = bar_index + 40
    line.new(bar_index, l_tp, ext, l_tp, color=color.green, width=2, style=line.style_dashed)
    line.new(bar_index, close, ext, close, color=color.lime, width=2)
    line.new(bar_index, l_sl, ext, l_sl, color=color.red,   width=2, style=line.style_dashed)
    rr_v = (l_tp - close) / (close - l_sl)
    txt = "LONG BOS\nEntrada: " + str.tostring(close, "#.00") +
          "\nTP: "    + str.tostring(l_tp,  "#.00") +
          "\nSL: "    + str.tostring(l_sl,  "#.00") +
          "\nR:R "    + str.tostring(rr_v,  "#.0") + ":1" +
          "\nRiesgo $" + str.tostring(math.round((close - l_sl) * 50), "#")
    label.new(bar_index, l_sl - atr_v, txt,
              color=color.new(color.green, 10), textcolor=color.black,
              style=label.style_label_up, size=size.normal)

if bos_s and (s_sl - close) > 3
    ext = bar_index + 40
    line.new(bar_index, s_tp, ext, s_tp, color=color.green, width=2, style=line.style_dashed)
    line.new(bar_index, close, ext, close, color=color.orange, width=2)
    line.new(bar_index, s_sl, ext, s_sl, color=color.red,    width=2, style=line.style_dashed)
    rr_v = (close - s_tp) / (s_sl - close)
    txt = "SHORT BOS\nEntrada: " + str.tostring(close, "#.00") +
          "\nTP: "    + str.tostring(s_tp,  "#.00") +
          "\nSL: "    + str.tostring(s_sl,  "#.00") +
          "\nR:R "    + str.tostring(rr_v,  "#.0") + ":1" +
          "\nRiesgo $" + str.tostring(math.round((s_sl - close) * 50), "#")
    label.new(bar_index, s_sl + atr_v, txt,
              color=color.new(color.red, 10), textcolor=color.white,
              style=label.style_label_down, size=size.normal)

// PLOTS
plot(ema50, "EMA Tendencia", color.new(color.yellow, 20), 2)
plot(ph_ok ? lph : na, "Resistencia", color.new(color.red,   30), 1, plot.style_linebr)
plot(pl_ok ? lpl : na, "Soporte",     color.new(color.green, 30), 1, plot.style_linebr)

plotshape(not na(ph), style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.tiny)
plotshape(not na(pl), style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.tiny)
plotshape(bos_l, style=shape.labelup,   location=location.belowbar, color=color.lime,   textcolor=color.black, text="BOS+", size=size.small)
plotshape(bos_s, style=shape.labeldown, location=location.abovebar, color=color.red,    textcolor=color.white, text="BOS-", size=size.small)

bgcolor(lon   ? color.new(color.blue,   93) : na)
bgcolor(ny    ? color.new(color.orange, 93) : na)
bgcolor(news  ? color.new(color.red,    85) : na)

// TABLA
var table t = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black,55), border_color=color.new(color.gray,50), border_width=1)

if barstate.islast
    cg = color.new(color.green, 20)
    cr = color.new(color.red,   20)
    cn = color.new(color.gray,  35)
    ch = color.new(color.navy,  15)
    table.cell(t,0,0,"BLUE GUARDIAN",    text_color=color.white,  bgcolor=ch, text_size=size.small)
    table.cell(t,1,0,"XAUUSD Senales",   text_color=color.yellow, bgcolor=ch, text_size=size.small)
    table.cell(t,0,1,"Sesion",           text_color=color.white, text_size=size.tiny)
    table.cell(t,1,1,sesion ? (lon?"Londres":"NY") : "Cerrada", bgcolor=sesion?cg:cn, text_color=color.white, text_size=size.tiny)
    table.cell(t,0,2,"Noticias",         text_color=color.white, text_size=size.tiny)
    table.cell(t,1,2,news?"HOY - No operar":"Sin noticias", bgcolor=news?cr:cg, text_color=color.white, text_size=size.tiny)
    table.cell(t,0,3,"RSI H4",           text_color=color.white, text_size=size.tiny)
    table.cell(t,1,3,str.tostring(math.round(rsi4h,1)) + (rsi4h>50?" Alcista":" Bajista"), bgcolor=rsi4h>50?cg:cr, text_color=color.white, text_size=size.tiny)
    table.cell(t,0,4,"Tendencia EMA",    text_color=color.white, text_size=size.tiny)
    table.cell(t,1,4,close>ema50?"ALCISTA":"BAJISTA", bgcolor=close>ema50?cg:cr, text_color=color.white, text_size=size.tiny)
    table.cell(t,0,5,"Senales Hoy",      text_color=color.white, text_size=size.tiny)
    table.cell(t,1,5,str.tostring(ds)+" / 2", bgcolor=ds<2?cg:cr, text_color=color.white, text_size=size.tiny)
    table.cell(t,0,6,"Estado",           text_color=color.white, text_size=size.tiny)
    table.cell(t,1,6,sesion and not news and ds<2?"BUSCANDO...":"ESPERAR", bgcolor=sesion and not news and ds<2?cg:cn, text_color=color.white, text_size=size.tiny)
